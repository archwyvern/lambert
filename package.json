{
  "name": "lambert",
  "version": "0.7.0",
  "description": "Shape-based height field authoring for normal maps. 3D but not 3D, done the hard way.",
  "type": "module",
  "license": "MIT",
  "author": "Archwyvern <codekestrel@googlemail.com>",
  "homepage": "https://github.com/archwyvern/lambert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archwyvern/lambert.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "selftest": "electron-vite build && electron . --selftest",
    "test": "vitest run",
    "test:watch": "vitest",
    "dav:serve": "tsx tests/webdav/serve.ts",
    "typecheck": "tsc --noEmit",
    "eval": "tsx src/cli/evaluate.ts",
    "gen-goldens": "tsx tests/golden/gen.ts",
    "dist": "electron-vite build && electron-builder",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dist:win": "electron-vite build && electron-builder --win"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "@carapace/shell": "link:../carapace/packages/shell",
      "@carapace/primitives": "link:../carapace/packages/primitives"
    }
  },
  "devDependencies": {
    "@fluentui/react-icons": "^2.0.328",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@webgpu/types": "^0.1.70",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@carapace/primitives": "github:archwyvern/carapace#master",
    "@carapace/shell": "github:archwyvern/carapace#master",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "electron-updater": "^6.8.9",
    "fast-png": "^8.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  }
}
